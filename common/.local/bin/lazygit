#!/usr/bin/env bash
set -euo pipefail

CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/lazygit"

BASE_CONF=""
ARGS=()
TMUX_MODE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tmux)
      TMUX_MODE=true
      shift
      ;;
    -ucf|--use-config-file)
      shift
      [[ $# -gt 0 ]] && shift
      ;;
    -ucf=*|--use-config-file=*)
      shift
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if $TMUX_MODE; then
  BASE_CONF="$CONF_DIR/config_tmux.yml"
else
  BASE_CONF="$CONF_DIR/config.yml"
fi

THEME_STATE="$HOME/.local/state/current_theme"
if [[ -f "$THEME_STATE" ]]; then
  THEME_CONF="$CONF_DIR/themes/$(cat "$THEME_STATE").yml"
fi

LAZYGIT_BIN=""
while IFS= read -r candidate; do
  [[ "$(realpath "$candidate")" == "$(realpath "$0")" ]] && continue
  LAZYGIT_BIN="$candidate"
  break
done < <(type -aP lazygit 2>/dev/null)
[[ -n "$LAZYGIT_BIN" ]] || { echo "lazygit: real binary not found" >&2; exit 1; }

if [[ -n "${THEME_CONF:-}" && -f "$THEME_CONF" ]]; then
  exec "$LAZYGIT_BIN" --use-config-file="$BASE_CONF,$THEME_CONF" "${ARGS[@]}"
else
  exec "$LAZYGIT_BIN" --config-file="$BASE_CONF" "${ARGS[@]}"
fi
