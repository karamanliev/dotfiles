{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_next": "ctrl+f",
    "messages_previous": "ctrl+b",
    "display_thinking": "ctrl+t",
    "session_child_first": "<leader>j",
    "session_child_cycle": "l",
    "session_child_cycle_reverse": "h",
    "session_parent": "k",
    "variant_cycle": "shift+tab",
    "session_list": "ctrl+space",
    "session_timeline": "alt+space",
    "model_list": "ctrl+q"
  },
  // opencode-vim settings
  "vim_enter_submit": true,
  "prompt_max_height": 25,
  "prompt_scrollbar": true,
  "plugin": ["@slkiser/opencode-quota"]
}
