{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_next": "ctrl+f",
    "messages_previous": "ctrl+b",
    "display_thinking": "ctrl+t",
    "session_child_first": "<leader>j",
    "session_child_cycle": "l",
    "session_child_cycle_reverse": "h",
    "session_parent": "k",
    "variant_cycle": "ctrl+e",
    "session_list": "ctrl+space",
    "session_timeline": "alt+space",
    "model_list": "ctrl+q",
    "session_rename": "ctrl+y"
  },
  // opencode-vim settings
  "plugin": [
    "@slkiser/opencode-quota",
    [
      "opencode-vim",
      {
        "autoUpdate": true,
        "vim": {
          "defaultMode": "insert",
          "keymapTimeout": 500,
          "pendingDisplayDelay": 120,
          "cursorStyles": {
            "insert": {
              "style": "line",
              "blinking": true
            },
            "normal": {
              "style": "block",
              "blinking": true
            }
          },
          "debug": false,
          "debugPath": "/home/ico/.cache/opencode/opencode-vim.log",
          "keymaps": {
            "insert": {
              // "kj": "normal"
            },
            "normal": {
              "<CR>": "submit",
              "Y": "y$"
            }
          }
        }
      }
    ]
  ]
}
