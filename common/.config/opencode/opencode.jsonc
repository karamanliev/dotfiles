{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://192.168.100.2:11434/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "enabled_providers": [
    "openai",
    "github-copilot",
    "llama.cpp",
    "opencode-go"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    },
  },
  "agent": {
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "max",
    },
  },
  "compaction": {
    "auto": true
  },
  "share": "disabled",
  "plugin": [
    "cc-safety-net",
    "@slkiser/opencode-quota"
  ],
  "experimental": {
    "disable_paste_summary": true,
    "quotaToast": {
      "enableToast": false,
      "percentDisplayMode": "used",
      "formatStyle": "grouped",
      "enabledProviders": [
        "openai",
        "opencode-go"
      ],
    },
  },
}
