{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
  },
  "agent": {
    "general": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "approve": {
      "description": "Ask-first mode with safe auto-allow",
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "ls*": "allow",
          "pwd*": "allow",
          "which*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "find": "allow",
          "find *": "allow",
          "fd": "allow",
          "fd *": "allow",
          "fdfind": "allow",
          "fdfind *": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": false
  },
  "share": "disabled",
  "plugin": [
    "opencode-claude-auth",
    "cc-safety-net",
  ]
}
