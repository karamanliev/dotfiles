{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai",
    "opencode",
    "opencode-go",
    "google",
    "neuralwatt"
    // "llama.cpp",
    // "openrouter",
    // "github-copilot"
  ],
  "permission": {
    "websearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
  },
  "agent": {
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
  },
  "compaction": {
    "auto": true
  },
  "share": "disabled",
  "plugin": [
    "cc-safety-net",
    "@slkiser/opencode-quota"
  ],
  "experimental": {
    "disable_paste_summary": true,
    "quotaToast": {
      "enableToast": false,
      "percentDisplayMode": "used",
      "formatStyle": "grouped",
      "enabledProviders": [
        "openai",
        "opencode-go",
        "google"
      ],
    },
  },
}
