{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp",
      "options": {
        "baseURL": "http://192.168.100.2:11434/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "enabled_providers": [
    "anthropic",
    "openai",
    "github-copilot",
    "llama.cpp",
    "opencode-go"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
  },
  "agent": {
    "explore": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "approve": {
      "description": "Ask-first mode with safe auto-allow",
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "ls*": "allow",
          "pwd*": "allow",
          "which*": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "find": "allow",
          "find *": "allow",
          "fd": "allow",
          "fd *": "allow",
          "fdfind": "allow",
          "fdfind *": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true
  },
  "share": "disabled",
  "plugin": [
    "opencode-claude-auth",
    "cc-safety-net",
    "@slkiser/opencode-quota",
    "caveman-opencode-plugin"
  ],
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "percentDisplayMode": "used",
      "formatStyle": "grouped",
      "enabledProviders": [
        "openai",
        "opencode-go",
        "anthropic"
      ],
    },
  },
}
